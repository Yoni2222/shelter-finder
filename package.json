{
  "name": "shelter-finder",
  "version": "1.0.0",
  "description": "מאתר מקלטים ציבוריים - Israeli Public Shelter Finder",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:client": "cd client && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "build": "npm install --prefix client && npm run --prefix client build",
    "build:bundle": "node scripts/build-shelter-bundle.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.7.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
